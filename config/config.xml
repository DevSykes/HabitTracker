<?xml version="1.0" encoding="UTF-8"?>
<configuracion xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="esquema.xsd">
    <metadatos>
        <proyecto>HabitTracker</proyecto>
        <version>1.0</version>
        <descripcion>Gestor de hábitos saludables con integración de base de datos SQL</descripcion>
        <tecnologias>
            <item>Java 17</item>
            <item>MySQL</item>
            <item>XML</item>
        </tecnologias>
    </metadatos>
    
    <conexion_bbdd>
        <servidor>localhost</servidor>
        <puerto>3306</puerto>
        <usuario>root</usuario>
        <base_datos>gestor_habitos</base_datos>
    </conexion_bbdd>

    <preferencias_app>
        <idioma>es</idioma>
        <tema>oscuro</tema>
    </preferencias_app>
</configuracion>
